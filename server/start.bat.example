@echo off
REM Copy this file to start.bat and edit the values below for your setup.
REM start.bat is gitignored to keep your DDNS host private.
echo.
cd /d "%~dp0"

python -c "import flask" 2>nul
if errorlevel 1 (
    echo Installing Flask...
    python -m pip install -r requirements.txt
)

set PORT=25565
set DDNS_HOST=your-ddns-host.example.com
set DDNS_PORT=0
python app.py
pause
